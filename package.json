{
  "name": "@chan.run/ensure",
  "version": "0.3.0",
  "homepage": "https://www.chan.run/libraries/ensure",
  "description": "Type-safe errors without the boilerplate",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm run build",
    "typecheck": "tsc --noEmit",
    "docs:api": "node scripts/generate-api-docs.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "tsdown": "0.21.7",
    "typedoc": "0.28.18",
    "typedoc-plugin-frontmatter": "1.3.1",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerocity/ensure.chan.run.git"
  },
  "keywords": [
    "error",
    "errors",
    "typed-errors",
    "fault",
    "try-catch",
    "result",
    "typescript"
  ]
}
